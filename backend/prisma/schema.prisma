generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  name       String
  phone      String?
  role       String   @default("RETAIL_BUYER")
  avatar     String?
  state      String?
  district   String?
  bio        String?
  trustScore Float    @default(50.0)
  isVerified Boolean  @default(false)
  isOrganic  Boolean  @default(false)
  fcmToken   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())

  listings         CropListing[]
  inquiries        PurchaseInquiry[]
  wishlist         WishlistItem[]
  cartItems        CartItem[]
  sentMessages     Message[]         @relation("SenderMessages")
  receivedMessages Message[]         @relation("ReceiverMessages")
  alerts           PriceAlert[]
  notifications    Notification[]
  auditLogs        AuditLog[]

  @@map("users")
}

model CropListing {
  id               String   @id @default(cuid())
  cropName         String
  variety          String?
  quantity         Float
  unit             String   @default("kg")
  price            Float
  state            String
  district         String
  images           String[]
  harvestDate      DateTime?
  organicCertified Boolean  @default(false)
  description      String?
  status           String   @default("ACTIVE")

  farmerId   String
  farmer     User              @relation(fields: [farmerId], references: [id])
  inquiries  PurchaseInquiry[]
  wishlistedBy WishlistItem[]
  cartedBy   CartItem[]
  messages   Message[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @default(now())

  @@index([state, district])
  @@index([cropName])
  @@index([status])
  @@map("crop_listings")
}

model PurchaseInquiry {
  id        String   @id @default(cuid())
  message   String
  quantity  Float
  unit      String   @default("kg")
  status    String   @default("PENDING")

  listingId String
  listing   CropListing  @relation(fields: [listingId], references: [id])
  buyerId   String
  buyer     User         @relation(fields: [buyerId], references: [id])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @default(now())

  @@map("purchase_inquiries")
}

model WishlistItem {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  listingId String
  listing   CropListing @relation(fields: [listingId], references: [id])
  createdAt DateTime    @default(now())

  @@unique([userId, listingId])
  @@map("wishlist_items")
}

model CartItem {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  listingId String
  listing   CropListing @relation(fields: [listingId], references: [id])
  quantity  Float
  createdAt DateTime    @default(now())

  @@unique([userId, listingId])
  @@map("cart_items")
}

model CropPrice {
  id         String   @id @default(cuid())
  cropName   String
  variety    String?
  state      String
  district   String
  market     String?
  minPrice   Float
  maxPrice   Float
  modalPrice Float
  priceDate  DateTime @default(now())
  source     String   @default("mandi")
  createdAt  DateTime @default(now())

  @@index([cropName, state, district])
  @@index([cropName, priceDate])
  @@index([state, district])
  @@index([priceDate])
  @@map("crop_prices")
}

model CropPriceHistory {
  id         String   @id @default(cuid())
  cropName   String
  variety    String?
  state      String
  district   String
  market     String?
  minPrice   Float
  maxPrice   Float
  modalPrice Float
  priceDate  DateTime
  source     String   @default("mandi")
  createdAt  DateTime @default(now())

  @@index([cropName, state, district, priceDate])
  @@index([cropName, priceDate])
  @@index([state, district, priceDate])
  @@index([priceDate])
  @@map("crop_price_history")
}

model MarketTrend {
  id                 String   @id @default(cuid())
  cropName           String
  state              String?
  district           String?
  trendDirection     String   @default("stable")
  avgPrice           Float
  minPrice           Float
  maxPrice           Float
  priceChange        Float    @default(0)
  percentChange      Float    @default(0)
  periodDays         Int      @default(7)
  sampleSize         Int      @default(0)
  calculatedAt       DateTime @default(now())
  periodStart        DateTime
  periodEnd          DateTime

  @@index([cropName, state, district])
  @@index([cropName, calculatedAt])
  @@map("market_trends")
}

model PriceForecast {
  id               String   @id @default(cuid())
  cropName         String
  state            String?
  district         String?
  forecastDate     DateTime
  predictedPrice   Float
  confidenceLow    Float
  confidenceHigh   Float
  confidenceScore  Float    @default(0.8)
  modelUsed        String   @default("moving_average")
  actualPrice      Float?
  generatedAt      DateTime @default(now())

  @@index([cropName, state, district, forecastDate])
  @@index([cropName, forecastDate])
  @@map("price_forecasts")
}

model SeasonalPattern {
  id               String @id @default(cuid())
  cropName         String
  state            String?
  district         String?
  month            Int
  avgPrice         Float
  minPrice         Float
  maxPrice         Float
  priceVolatility  Float  @default(0)
  sampleYears      Int    @default(1)
  seasonType       String @default("normal")
  recommendation   String?
  updatedAt        DateTime @default(now())

  @@unique([cropName, state, district, month])
  @@index([cropName, month])
  @@map("seasonal_patterns")
}

model Message {
  id         String   @id @default(cuid())
  content    String
  senderId   String
  sender     User         @relation("SenderMessages", fields: [senderId], references: [id])
  receiverId String
  receiver   User         @relation("ReceiverMessages", fields: [receiverId], references: [id])
  listingId  String?
  listing    CropListing? @relation(fields: [listingId], references: [id])
  isRead     Boolean      @default(false)
  createdAt  DateTime     @default(now())

  @@index([senderId, receiverId])
  @@map("messages")
}

model PriceAlert {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  cropName    String
  state       String?
  district    String?
  targetPrice Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("price_alerts")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  body      String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
